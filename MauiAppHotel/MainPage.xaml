<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppHotel.MainPage"
             Title="App Hotel - Reserva">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Label Text="Dados da Hospedagem" 
                   FontSize="24" 
                   FontAttributes="Bold" 
                   HorizontalOptions="Center" 
                   TextColor="{StaticResource Primary}"/>

            <BoxView HeightRequest="1" Color="Gray" HorizontalOptions="Fill" />

            <Label Text="Escolha a Suíte:" FontAttributes="Bold" />
            <Picker x:Name="pck_suite" 
                    Title="Selecione uma opção..." />

            <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                <VerticalStackLayout Grid.Column="0">
                    <Label Text="Check-in:" FontAttributes="Bold" />
                    <DatePicker x:Name="dtp_checkin" 
                                Format="dd/MM/yyyy" />
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="1">
                    <Label Text="Check-out:" FontAttributes="Bold" />
                    <DatePicker x:Name="dtp_checkout" 
                                Format="dd/MM/yyyy" />
                </VerticalStackLayout>
            </Grid>

            <Label Text="Quantidade de Hóspedes:" FontAttributes="Bold" />
            <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
                <Label Grid.Column="0" 
                       Text="{Binding Source={x:Reference stp_hospedes}, Path=Value, StringFormat='{0:F0} hóspedes'}" 
                       VerticalOptions="Center" 
                       FontSize="18"/>
                <Stepper Grid.Column="1" 
                         x:Name="stp_hospedes" 
                         Minimum="1" 
                         Maximum="10" 
                         Increment="1" 
                         Value="1"/>
            </Grid>

            <Button Text="Avançar para Resumo" 
                    Clicked="OnAvancarClicked" 
                    Margin="0,20,0,0" />

            <Button Text="Sobre o Desenvolvedor" 
                    Clicked="OnSobreClicked" 
                    BackgroundColor="Gray" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>