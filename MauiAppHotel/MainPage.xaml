<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppHotel.MainPage"
             Title="App Hotel - Reserva">

    <ScrollView>
        <VerticalStackLayout Padding="25" Spacing="20">

            <VerticalStackLayout HorizontalOptions="Center" Margin="0,10,0,10">
                <Label Text="Maui Hotel" FontSize="30" FontFamily="Kalam" FontAttributes="Bold" TextColor="{StaticResource Primary}" HorizontalOptions="Center"/>
                <Label Text="Monte a sua hospedagem perfeita" FontSize="13" TextColor="Gray" HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <Frame BackgroundColor="#1E1E1E" BorderColor="#333" CornerRadius="12" Padding="15">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Escolha a sua Acomodação" TextColor="{StaticResource Primary}" FontAttributes="Bold" FontSize="16"/>
                    <Picker x:Name="pck_suite" Title="Toque para selecionar..." TitleColor="Gray" TextColor="White" />
                </VerticalStackLayout>
            </Frame>

            <Frame BackgroundColor="#1E1E1E" BorderColor="#333" CornerRadius="12" Padding="15">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Período da Estadia" TextColor="{StaticResource Primary}" FontAttributes="Bold" FontSize="16"/>
                    <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                        <VerticalStackLayout Grid.Column="0" Spacing="5">
                            <Label Text="Check-in:" TextColor="LightGray" FontSize="12"/>
                            <DatePicker x:Name="dtp_checkin" Format="dd/MM/yyyy" TextColor="White"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Spacing="5">
                            <Label Text="Check-out:" TextColor="LightGray" FontSize="12"/>
                            <DatePicker x:Name="dtp_checkout" Format="dd/MM/yyyy" TextColor="White"/>
                        </VerticalStackLayout>
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <Frame BackgroundColor="#1E1E1E" BorderColor="#333" CornerRadius="12" Padding="15">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Quantidade de Hóspedes" TextColor="{StaticResource Primary}" FontAttributes="Bold" FontSize="16"/>
                    <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
                        <Label Grid.Column="0" Text="{Binding Source={x:Reference stp_hospedes}, Path=Value, StringFormat='{0:F0} Pessoas'}" TextColor="White" VerticalOptions="Center" FontSize="18"/>
                        <Stepper Grid.Column="1" x:Name="stp_hospedes" Minimum="1" Maximum="10" Increment="1" Value="1"/>
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <Button Text="CALCULAR TOTAL DA RESERVA" Clicked="OnAvancarClicked" BackgroundColor="{StaticResource Primary}" TextColor="Black" FontAttributes="Bold" CornerRadius="8" HeightRequest="50" Margin="0,15,0,0" />
            <Button Text="Sobre o Desenvolvedor" Clicked="OnSobreClicked" BackgroundColor="Transparent" TextColor="Gray" FontAttributes="Italic" TextTransform="None"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>